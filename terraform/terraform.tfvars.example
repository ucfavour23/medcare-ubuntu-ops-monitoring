aws_region    = "us-east-1"
alert_email   = "your-email@example.com"
key_name      = "your-existing-keypair-name"
ssh_cidr      = "YOUR_PUBLIC_IP/32"
instance_type = "t3.micro"
repository_url = "https://github.com/ucfavour23/medcare-ubuntu-ops-monitoring.git"

# Optional HTTPS setup.
# 1. Buy or use a domain/subdomain.
# 2. Create an A record pointing to the EC2 public IP.
# 3. Set dashboard_domain and re-apply Terraform.
dashboard_domain      = "ops.example.com"
certificate_email    = "your-email@example.com"
public_dashboard_cidr = "0.0.0.0/0"
